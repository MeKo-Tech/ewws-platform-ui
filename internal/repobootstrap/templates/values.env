# values.env — plain (non-secret) environment defaults for this app.
#
# Layout convention:
#   values.env                   — base, applied to every stage
#   values.staging.env           — staging-only overrides (optional)
#   values.prod.env              — prod-only overrides (optional)
#
# These files are committed as-is. Real secrets belong in values.sops.env
# (same per-stage convention).
#
# Format: KEY=value, one per line. Comments start with `#`.
#
# Example:
#   LOG_LEVEL=info
#   FEATURE_NEW_LAYOUT=true
#   PUBLIC_BASE_URL=https://example.apps.meko.work
